{#
/**
 * @file
 * Theme override to display a single Drupal page.
 */
#}

<div class="min-h-screen bg-gray-50 flex flex-col">

  <header class="bg-indigo-700 text-white shadow">
    <div class="max-w-2xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="{{ front_page }}" class="text-xl font-bold tracking-tight hover:text-indigo-200 transition">&#128379; Simple Voting</a>
      {% if logged_in %}
        <nav class="text-sm">
          {{ page.primary_menu }}
        </nav>
      {% endif %}
    </div>
  </header>

  {% if page.highlighted %}
    <div class="bg-yellow-50 border-b border-yellow-200 text-yellow-800 text-sm px-4 py-2">
      {{ page.highlighted }}
    </div>
  {% endif %}

  {% if page.breadcrumb %}
    <div class="max-w-2xl mx-auto px-4 pt-3 text-sm text-gray-500">{{ page.breadcrumb }}</div>
  {% endif %}

  <main class="flex-1 max-w-2xl w-full mx-auto px-4 py-10">
    {% if page.messages %}{{ page.messages }}{% endif %}
    {% if page.content_top %}{{ page.content_top }}{% endif %}
    {{ page.content }}
    {% if page.content_bottom %}{{ page.content_bottom }}{% endif %}
  </main>

  <footer class="border-t border-gray-200 text-center text-xs text-gray-400 py-4">
    {% if page.footer %}{{ page.footer }}{% endif %}
    Simple Voting &mdash; Drupal by @cassiodourado
  </footer>

</div>
