# Sensitive local settings
/web/sites/*/settings.local.php
/web/sites/*/services.local.yml
.env
.env.local
.env.*.local

# User-generated files
/web/sites/*/files
/web/sites/*/private
/private

# Drupal test environment
/web/sites/simpletest

# Composer generated files
/vendor/
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/
/web/libraries/

# Drupal cache/generated assets
/web/sites/*/files/css/
/web/sites/*/files/js/
/web/sites/*/files/styles/
/web/sites/*/files/php/

# Node/build artifacts
node_modules/
npm-debug.log
yarn-error.log
yarn-debug.log
/build/
/dist/
/.sass-cache/
/coverage/

# Logs
*.log
*.log.*

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~
.#*

# PHP temp files
*.php~
*.php.bak

# IDE / OS files
.idea/
.vscode/
.DS_Store
Thumbs.db
.project
.buildpath
.settings
.sublime-project
.sublime-workspace

# Database backups: ignore all except delivery folder
*.sql
*.sql.gz
*.sql.bz2
*.sql.zip
!database/
!database/*.sql
!database/*.sql.gz